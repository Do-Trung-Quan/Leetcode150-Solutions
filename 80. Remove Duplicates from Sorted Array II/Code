class Solution {
    public int removeDuplicates(int[] nums) {
        int dup = 0;
        int p = 1;
        for(int i = 1;i<nums.length;i++){
            if(nums[p-1] != nums[i] || nums[p-1] == nums[i] && dup==0){
                nums[p] = nums[i];
                if(nums[p-1] == nums[i]) dup++;
                else dup = 0;
                p++;
            }
        }
        return p;
    }
}
